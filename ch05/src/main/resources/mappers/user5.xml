<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.ch05.dao.User5DAO">

    <!-- id 값은 DAO의 메서드명으로 맞춰줌 -->
    <select id="select" resultType="org.example.ch05.dto.User5DTO">
        select * from user5 where seq=#{seq};
    </select>

    <select id="selectAll" resultType="org.example.ch05.dto.User5DTO">
        select * from user5;
    </select>

    <insert id="insert">
        Insert into user5 set
                            name=#{name},
                            gender=#{gender},
                            age=#{age},
                            addr=#{addr};
    </insert>

    <update id="update">
        Update user5 set
                    name=#{name},
                    gender=#{gender},
                    age=#{age},
                    addr=#{addr}
                    where seq=#{seq};
    </update>

    <delete id="delete">
        delete from user5 where seq=#{seq};
    </delete>
</mapper>