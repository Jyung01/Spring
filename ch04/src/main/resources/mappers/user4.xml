<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.ch04.dao.User4DAO">

    <!-- id 값은 DAO의 메서드명으로 맞춰줌 -->
    <select id="select">
        select * from user4 where userid=#{userid};
    </select>

    <select id="selectAll">
        select * from user4;
    </select>

    <insert id="insert">
        Insert into user4 set
                            userid=#{userid},
                            name=#{name},
                            gender=#{gender},
                            age=#{age},
                            hp=#{hp},
                            addr=#{addr};
    </insert>

    <update id="update">
        Update user4 set
                    name=#{name},
                    gender=#{gender},
                    age=#{age},
                    hp=#{hp},
                    addr=#{addr}
                    where userid=#{userid};
    </update>

    <delete id="delete">
        delete from user4 where userid=#{userid};
    </delete>
</mapper>